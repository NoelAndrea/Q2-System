# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database  (database name matches setup.sql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=digital_twin

# JWT Secret (change this to a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_abc123xyz789
JWT_EXPIRES_IN=7d

# CORS - Frontend URL
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
